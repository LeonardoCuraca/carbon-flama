generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MOZO
  CAJA
  COCINA
  INVENTARIO
}

enum TableStatus {
  DISPONIBLE
  PEDIDO_ENVIADO
  RESERVADO
}

enum OrderStatus {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
  PAGADO
}

enum OrderItemStatus {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}

enum SupplyStatus {
  OK
  WARNING
  CRITICAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  role      Role     @default(MOZO)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id              Int         @id
  status          TableStatus @default(DISPONIBLE)
  zone            String      // Salón A, Salón B, Terraza
  reservationNote String?
  orders          Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  products  Product[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  price       Float
  description String?
  image       String?
  isAvailable Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  optionGroups ProductOptionGroup[]
}

model Order {
  id          String      @id @default(cuid())
  tableId     Int
  table       Table       @relation(fields: [tableId], references: [id])
  userId      String
  waiter      User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDIENTE)
  total       Float       @default(0)
  tip         Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  payments    Payment[]
  invoice     Invoice?
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  quantity    Int
  notes       String?
  modifiers   Json?
  subtotal    Float
  status      OrderItemStatus @default(PENDIENTE)
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  amount        Float
  method        PaymentMethod
  transactionId String?
  createdAt     DateTime      @default(now())
}

model Supply {
  id          String       @id @default(cuid())
  name        String
  stock       Float
  minRequired Float
  unit        String       // Kg, Lt, Unidades
  status      SupplyStatus @default(OK)
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id])
  documentType  String   // DNI, RUC
  documentNum   String
  clientName    String
  totalAmount   Float
  issuedAt      DateTime @default(now())
}

model ProductOptionGroup {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String          // "Salsas", "Acompañamiento", "Extras"
  type        String          // "SINGLE" o "MULTIPLE"
  required    Boolean         @default(false)
  options     ProductOption[]
}

model ProductOption {
  id          String             @id @default(cuid())
  groupId     String
  group       ProductOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String             // "Mayonesa", "Ketchup", "Papas Fritas", "Huevo Frito"
  price       Float              @default(0)
}
